# Application
NODE_ENV=development
PORT=3000

# Database
# Valores soportados: sqlite | postgres | mssql
DB_TYPE=sqlite
DB_DATABASE=./data/app.db

# --- Para SQL Server local ---
# DB_TYPE=mssql
# DB_HOST=localhost
# DB_PORT=1433
# DB_USERNAME=sa
# DB_PASSWORD=YourStrong!Passw0rd
# DB_DATABASE=appdb
# DB_SSL=true
# DB_TRUST_SERVER_CERTIFICATE=true

# --- Para Azure SQL ---
# DB_TYPE=mssql
# DB_HOST=<server>.database.windows.net
# DB_PORT=1433
# DB_USERNAME=adminuser
# DB_PASSWORD=<password>
# DB_DATABASE=appdb
# DB_SSL=true
# DB_TRUST_SERVER_CERTIFICATE=false

# Si es true, TypeORM crea/actualiza el esquema al arrancar. En prod se recomienda false + migraciones.
DB_SYNCHRONIZE=true

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h

# External API
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_DEFAULT_VS_CURRENCY=usd

# Azure Blob Storage (para uploads vía SAS)
# AZURE_STORAGE_ACCOUNT=pruebastoracct
# AZURE_STORAGE_KEY=<primary-key>
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER=uploads
# AZURE_STORAGE_SAS_TTL_MINUTES=10
