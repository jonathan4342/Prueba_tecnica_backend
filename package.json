{
  "name": "prueba-tecnica-backend",
  "version": "1.0.0",
  "description": "API REST en Node.js con arquitectura hexagonal (puertos y adaptadores) que consume la API financiera pública de CoinGecko.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "test": "jest --runInBand --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.ts\""
  },
  "keywords": [
    "nodejs",
    "express",
    "typescript",
    "typeorm",
    "hexagonal-architecture",
    "ports-and-adapters"
  ],
  "author": "Papi <osoriogarrido7@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "inversify": "^6.0.2",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
